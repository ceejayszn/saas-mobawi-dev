generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id           String          @id @default(uuid())
  name         String
  type         String          // "HOTEL", "RETAIL_SHOP", "PHARMACY"
  status       String          @default("ACTIVE")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  
  users        User[]
  sales        Sale[]
  expenses     Expense[]
  productions  Production[]
  personnels   Personnel[]
  products     Product[]
  auditLogs    AuditLog[]
  activityLogs ActivityLog[]
  deviceLogs   DeviceLog[]
  systemHealth SystemHealth[]

  @@index([status])
  @@index([type])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  oldValue   String?
  newValue   String?
  user       String
  time       DateTime @default(now())
  device     String
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([time])
  @@index([user])
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  user       String
  time       DateTime @default(now())
  device     String
  action     String
  result     String
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([time])
  @@index([action])
}

model DeploymentLog {
  id        Int      @id @default(autoincrement())
  status    String
  component String   // e.g., "Railway", "Server", "Database", "API"
  time      DateTime @default(now())
  logs      String?
  createdBy String?  // Who triggered the deployment

  @@index([time])
  @@index([status])
}

model BackupLog {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  size      Int
  duration  Int      // in seconds
  result    String   // "Success", "Failed"

  @@index([date])
}

model DeviceLog {
  id          Int      @id @default(autoincrement())
  deviceName  String
  user        String
  lastSync    DateTime
  isOnline    Boolean  @default(false)
  appVersion  String
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([lastSync])
  @@index([isOnline])
}

model SystemHealth {
  id              Int      @id @default(autoincrement())
  databaseOnline  Boolean  @default(true)
  railwayOnline   Boolean  @default(true)
  apiOnline       Boolean  @default(true)
  lastBackupDate  DateTime?
  backupSuccess   Boolean  @default(true)
  syncStatus      String   @default("OK")
  appVersion      String
  buildNumber     String
  time            DateTime @default(now())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([time])
}

model NotificationCenter {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   // e.g., "Error", "Warning", "Info"
  isRead    Boolean  @default(false)
  time      DateTime @default(now())

  @@index([isRead])
  @@index([time])
}

model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  role       String
  password   String   // Stored as salted hash, never plain text
  isActive   Boolean  @default(true)
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
  @@index([role])
  @@index([isActive])
}

model Sale {
  id         Int      @id @default(autoincrement())
  amount     Float
  date       DateTime @default(now())
  user       String
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([date])
  @@index([businessId, date])
}

model Expense {
  id         Int      @id @default(autoincrement())
  amount     Float
  category   String
  date       DateTime @default(now())
  user       String
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([date])
  @@index([category])
  @@index([businessId, date])
}

model Production {
  id         Int      @id @default(autoincrement())
  item       String
  quantity   Int
  date       DateTime @default(now())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([date])
}

model Personnel {
  id               Int      @id @default(autoincrement())
  name             String
  role             String
  phone            String
  assignment       String?
  amountDue        Float    @default(0.0)
  amountPaid       Float    @default(0.0)
  balance          Float    @default(0.0)
  businessId       String
  business         Business @relation(fields: [businessId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([businessId])
  @@index([role])
}

model Product {
  id         String   @id @default(uuid())
  name       String
  price      Float
  isActive   Boolean  @default(true)
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
}

