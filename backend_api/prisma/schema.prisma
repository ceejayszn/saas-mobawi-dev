generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  oldValue  String?
  newValue  String?
  user      String
  time      DateTime @default(now())
  device    String
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  user      String
  time      DateTime @default(now())
  device    String
  action    String
  result    String
}

model DeploymentLog {
  id        Int      @id @default(autoincrement())
  status    String
  component String // e.g., "Railway", "Server", "Database", "API"
  time      DateTime @default(now())
  logs      String?
}

model BackupLog {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  size      Int
  duration  Int      // in seconds
  result    String   // "Success", "Failed"
}

model DeviceLog {
  id          Int      @id @default(autoincrement())
  deviceName  String
  user        String
  lastSync    DateTime
  isOnline    Boolean  @default(false)
  appVersion  String
}

model SystemHealth {
  id              Int      @id @default(autoincrement())
  databaseOnline  Boolean  @default(true)
  railwayOnline   Boolean  @default(true)
  apiOnline       Boolean  @default(true)
  lastBackupDate  DateTime?
  backupSuccess   Boolean  @default(true)
  syncStatus      String   @default("OK")
  appVersion      String
  buildNumber     String
  time            DateTime @default(now())
}

model NotificationCenter {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   // e.g., "Error", "Warning", "Info"
  isRead    Boolean  @default(false)
  time      DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  role      String
  password  String
  isActive  Boolean  @default(true)
}

model Sale {
  id        Int      @id @default(autoincrement())
  amount    Float
  date      DateTime @default(now())
  user      String
}

model Expense {
  id        Int      @id @default(autoincrement())
  amount    Float
  category  String
  date      DateTime @default(now())
  user      String
}

model Production {
  id        Int      @id @default(autoincrement())
  item      String
  quantity  Int
  date      DateTime @default(now())
}

model Personnel {
  id               Int      @id @default(autoincrement())
  name             String
  role             String
  phone            String
  assignment       String?
  amountDue        Float    @default(0.0)
  amountPaid       Float    @default(0.0)
  balance          Float    @default(0.0)
}
